# Database Configuration
# Para desarrollo local, usar SQLite:
# DATABASE_URL=file:./dev.db
# 
# Para producción en Vercel, usar una base de datos externa:
# - PlanetScale (MySQL) - gratis hasta 5GB
# - Supabase (PostgreSQL) - gratis hasta 500MB
# - Neon (PostgreSQL) - gratis hasta 3GB
# -Railway (PostgreSQL) - gratis hasta 3GB

DATABASE_URL=file:./.vercel/sqlite.db
